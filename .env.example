# Auth Backend Real (SAM Lambda — puerto 3003)
VITE_AUTH_API_URL=http://localhost:3003

# ── Amazon Cognito ───────────────────────────────────────────────
# Configurar con los valores del User Pool real.
# Ver: demo-ticketing-auth-backend/README.md para instrucciones de creación.

# Dominio del Cognito Hosted UI (sin https://)
# Ejemplo: ticketera-dev.auth.us-east-1.amazoncognito.com
VITE_COGNITO_DOMAIN=ticketera-dev.auth.us-east-1.amazoncognito.com

# App Client ID del User Pool
VITE_COGNITO_CLIENT_ID=REPLACE_WITH_YOUR_CLIENT_ID

# URL de callback registrada en el App Client (debe coincidir exactamente)
VITE_COGNITO_REDIRECT_URI=http://localhost:5173/auth/callback

# OAuth 2.0 logout redirect
VITE_COGNITO_LOGOUT_URI=http://localhost:5173

# AWS Region del User Pool
VITE_COGNITO_REGION=us-east-1

# ── API Security ───────────────────────────────────────────────
# API Key para invocar los endpoints de LocalStack / AWS
VITE_API_KEY=dev-local-key
